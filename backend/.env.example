# MongoDB connection string
MONGO_URI=

# JWT secret key (use a long, random string in production)
JWT_SECRET=MYAPP23234

# Port for the Express server (defaults to 5000 if not set)
PORT=3000

# Allowed CORS origins (comma-separated, e.g. http://localhost:5173,https://your-app.vercel.app)
CORS_ORIGIN=
